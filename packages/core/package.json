{
  "name": "@uddi/core",
  "version": "0.1.0",
  "description": "UDDI core cryptography, DID generation, and key management",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.mjs",
      "require": "./dist/identity/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    },
    "./vc": {
      "types": "./dist/vc/index.d.ts",
      "import": "./dist/vc/index.mjs",
      "require": "./dist/vc/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/identity/index.ts src/types/index.ts src/vc/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "dev": "tsup src/index.ts src/identity/index.ts src/types/index.ts src/vc/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "@scure/base": "^1.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "license": "Apache-2.0"
}
