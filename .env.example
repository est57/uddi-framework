# UDDI API runtime
UDDI_ENV=development
UDDI_HTTP_ADDR=:8080
UDDI_GRPC_ADDR=:9090

# Local development adapters
UDDI_BLOCKCHAIN_RPC=memory://local
UDDI_ZKP_SERVICE_URL=memory://zkp

# Optional persistence. Leave empty to use in-memory stores.
UDDI_DATABASE_URL=postgres://uddi:uddi_dev_password@127.0.0.1:5432/uddi?sslmode=disable
UDDI_REDIS_URL=redis://127.0.0.1:6379/0

# Comma-separated CORS origins.
UDDI_ALLOWED_ORIGINS=*

# Development only. Replace before any shared environment.
UDDI_JWT_SECRET=dev-secret-change-in-production

# Optional integration test targets.
UDDI_TEST_DATABASE_URL=postgres://uddi:uddi_dev_password@127.0.0.1:5432/uddi?sslmode=disable
UDDI_TEST_REDIS_URL=redis://127.0.0.1:6379/0
